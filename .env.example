# Copy to .env and fill in real credentials before running in LIVE mode.

# HubSpot — private app token
HUBSPOT_API_KEY=your-hubspot-private-app-token

# Salesforce connected app
SALESFORCE_INSTANCE_URL=https://yourorg.salesforce.com
SALESFORCE_ACCESS_TOKEN=your-salesforce-oauth-access-token

# Slack incoming webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# Pipeline behaviour
# Set to "false" to run against real integrations
DRY_RUN=true

# Score drop (in points) that triggers a Slack alert + HubSpot task
ALERT_THRESHOLD_PCT=20

# Lookback window in days
TREND_WINDOW_DAYS=7
